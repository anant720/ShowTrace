# ShadowTrace Backend — Environment Configuration
# Copy to .env and fill in values

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=ShadowTrace
MONGO_DB_NAME=shadowtrace

# Security
API_KEY=shadowtrace-dev-key
CORS_ORIGINS=["http://localhost:3000","chrome-extension://*"]

# Rate Limiting
RATE_LIMIT_RPM=60

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
